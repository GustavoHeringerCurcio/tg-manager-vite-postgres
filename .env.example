# ── Deployment ─────────────────────────────────────────────────────
# For production (VPS / Docker Compose + EasyPanel Traefik):
#   Copy this file to .env in the project ROOT, fill in real values,
#   then run: docker compose up -d
#
# For local development:
#   Copy this file to server/.env, set DOMAIN=localhost,
#   then run: pnpm dev:server  +  pnpm dev:frontend
# ────────────────────────────────────────────────────────────────────

NODE_ENV=production
APP_PORT=3000
DOMAIN=botflix.example.com
ADMIN_PASSWORD=admin-botflix

# ── Database ────────────────────────────────────────────────────────
POSTGRES_USER=botflix
POSTGRES_PASSWORD=botflix-pass
POSTGRES_DB=botflix
DATABASE_URL=postgresql://botflix:botflix-pass@db:5432/botflix?schema=public&connection_limit=20&pool_timeout=10

# ── LivePix (payment gateway) ───────────────────────────────────────
LIVEPIX_CLIENT_ID=change-me
LIVEPIX_CLIENT_SECRET=change-me
# LIVEPIX_REDIRECT_URL=https://t.me/your_bot_username
# (Optional — defaults to https://t.me/{DOMAIN})

# ── Limits ──────────────────────────────────────────────────────────
MAX_PIX_GENERATIONS=5
INTERACTION_RETENTION_DAYS=90
LOG_PAYLOADS=false
PAYMENT_POLL_WINDOW_MINUTES=30
