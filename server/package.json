{
  "name": "@botflix/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "test:setup-bot": "tsx ../scripts/setup-test-bot.ts",
    "test:reset-db": "tsx ../scripts/reset-test-db.ts",
    "test:load:start": "k6 run tests/load/scenarios/start-message.ts",
    "test:load:callback": "k6 run tests/load/scenarios/callback-query.ts",
    "test:load:mixed": "k6 run tests/load/scenarios/mixed.ts",
    "test:load:smoke": "k6 run tests/load/scenarios/mixed.ts --vus 2 --duration 15s",
    "test:load": "k6 run tests/load/scenarios/mixed.ts --vus 20 --duration 4m",
    "test:load:payment": "k6 run tests/load/scenarios/payment-concurrency.ts --vus 20 --duration 2m",
    "test:load:payment:50": "k6 run tests/load/scenarios/payment-concurrency.ts --vus 50 --duration 2m",
    "test:load:stress": "k6 run tests/load/scenarios/stress.ts --vus 20 --duration 2m",
    "test:load:stress:50": "k6 run tests/load/scenarios/stress.ts --vus 50 --duration 2m",
    "test:load:stress:100": "k6 run tests/load/scenarios/stress.ts --vus 100 --duration 2m",
    "test:load:stress:200": "k6 run tests/load/scenarios/stress.ts --vus 200 --duration 2m",
    "test:load:stress:300": "k6 run tests/load/scenarios/stress.ts --vus 300 --duration 1m30s",
    "test:load:dbpool": "k6 run tests/load/scenarios/payment-concurrency.ts --vus 50 --duration 2m",
    "test:load:cluster": "k6 run tests/load/scenarios/mixed.ts --vus 50 --duration 2m"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "compression": "^1.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
